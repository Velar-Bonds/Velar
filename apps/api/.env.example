# Supabase
SUPABASE_URL=https://nqdwmubpnaeukkocrnrs.supabase.co
SUPABASE_SERVICE_ROLE_KEY=          # Project Settings > API > service_role key

# Trustless Work (escrow Stellar)
TRUSTLESS_WORK_API_KEY=             # API key de Trustless Work
TRUSTLESS_WORK_API_URL=https://dev.api.trustlesswork.com   # testnet (mainnet: https://api.trustlesswork.com)
TRUSTLESS_WORK_PLATFORM_ADDRESS=    # se obtiene corriendo: npm run provision:wallets

# Stellar (classic assets + custody demo)
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_ENABLE_FRIENDBOT=true
# Las llaves secretas no se exponen al frontend. En demo se guardan en:
# apps/api/.stellar-wallets.json (gitignored), generado con npm run provision:wallets.

# Server
PORT=3001
WEB_URL=http://localhost:3000
# En producción (Vercel): orígenes del front separados por coma
# CORS_ORIGINS=https://velar-web.vercel.app,https://tu-preview.vercel.app
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Producción (Vercel/Render): pegá el JSON de .stellar-wallets.json como una línea
# STELLAR_WALLETS_JSON={"platform":{"publicKey":"G...","secret":"S..."},...}

# NOTA: para el escrow on-chain (custodia asistida en testnet) corré:
#   npm run provision:wallets
# Genera apps/api/.stellar-wallets.json (gitignored) con las llaves de custodia
# y publica la TRUSTLESS_WORK_PLATFORM_ADDRESS para pegar arriba.
